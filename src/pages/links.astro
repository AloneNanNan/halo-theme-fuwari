---
import MainGridLayout from "../layouts/MainGridLayout.astro";
---

<MainGridLayout title="${linksTitle + ' - ' + site.title}">
  <Fragment slot="head">
    <title th:text="${linksTitle + ' - ' + site.title}"></title>
    <style>
      .info-item {
        position: relative;
        padding-left: 1.1rem;
      }
      .info-item::before {
        content: "";
        position: absolute;
        left: 0.25rem;
        top: 50%;
        transform: translateY(-50%);
        width: 5px;
        height: 5px;
      }
      .collapse-icon.is-expanded {
        transform: rotate(180deg) !important;
      }
        border-radius: 50%;
        background-color: currentColor;
        opacity: 0.4;
      }
    </style>
  </Fragment>

  <section class="card-base onload-animation mb-4 px-6 py-6 md:px-9">
    <!-- 标题区域 -->
    <div class="mb-6 flex flex-col gap-2">
      <div class="flex items-center justify-between gap-4">
        <div class="flex flex-col gap-2">
          <h1 class="text-3xl font-bold text-90" th:text="${linksTitle}">
            友情链接
          </h1>
          <div class="text-sm text-50">
            <span class="icon-[material-symbols--link-rounded] mr-1"></span>
            <span>Friends links</span>
          </div>
        </div>
      </div>
    </div>

    <!-- 友链列表 -->
    <div th:if="${not #lists.isEmpty(groups)}" class="space-y-8">
      <section
        th:each="group, groupStat : ${groups}"
        th:if="${not #lists.isEmpty(group.links)}"
        th:style="|animation-delay: calc(var(--content-delay) + ${groupStat.index * 50}ms)|"
        class="onload-animation"
      >
        <div class="mb-4 flex items-center justify-between gap-4">
          <h2 class="text-xl font-bold text-90">
            <span th:text="${group.spec.displayName}">Group</span>
          </h2>
          <span
            class="rounded-lg bg-(--btn-regular-bg) px-2.5 py-1 text-xs font-bold text-(--btn-content)"
            th:text="${#lists.size(group.links)}">0</span
          >
        </div>

        <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          <a
            th:each="link, linkStat : ${group.links}"
            th:href="${link.spec.url}"
            th:title="${link.spec.displayName}"
            th:style="|animation-delay: calc(var(--content-delay) + ${(groupStat.index * 4 + linkStat.index) * 35}ms)|"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-card group min-h-28 items-start! justify-start! gap-4 rounded-xl p-4 text-left active:scale-95"
          >
            <img
              alt=""
              th:if="${not #strings.isEmpty(link.spec.logo)}"
              th:src="${link.spec.logo}"
              th:alt="${link.spec.displayName}"
              loading="lazy"
              class="h-12 w-12 shrink-0 rounded-xl bg-(--btn-regular-bg) object-cover transition group-hover:scale-105"
            />
            <div
              th:unless="${not #strings.isEmpty(link.spec.logo)}"
              class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-(--btn-regular-bg) text-(--primary)"
            >
              <span class="icon-[material-symbols--link-rounded] text-2xl"
              ></span>
            </div>
            <div class="min-w-0 flex-1">
              <div class="flex items-start gap-2">
                <div
                  class="min-w-0 flex-1 truncate text-base font-bold text-90 transition group-hover:text-(--primary)"
                  th:text="${link.spec.displayName}"
                >
                  Link
                </div>
                <span
                  class="icon-[fa6-solid--arrow-up-right-from-square] mt-0.5 shrink-0 text-sm text-30 transition group-hover:text-(--primary)"
                ></span>
              </div>
              <div
                th:if="${not #strings.isEmpty(link.spec.description)}"
                class="mt-1 line-clamp-2 text-sm leading-6 text-50"
                th:text="${link.spec.description}"
              >
                Description
              </div>
              <div
                class="mt-2 truncate text-xs font-medium text-30"
                th:text="${link.spec.url}"
              >
                https://example.com
              </div>
            </div>
          </a>
        </div>
      </section>
    </div>

    <div th:if="${#lists.isEmpty(groups)}" class="py-12 text-center text-50">
      暂无友情链接
    </div>
  </section>

  <!-- 折叠信息区域 -->
  <section
    th:if="${theme.config.links.enable_owner_info || theme.config.links.enable_requirements || theme.config.links.enable_disclaimer}"
    class="card-base onload-animation mb-4 px-6 py-6 md:px-9"
  >
    <h2 class="mb-4 text-xl font-bold text-90">
      <span>申请友链</span>
    </h2>

    <!-- 折叠面板容器 - 主题风格 -->
    <div class="space-y-2" id="links-accordion">
      <!-- 博客信息 -->
      <div
        th:if="${theme.config.links.enable_owner_info}"
        class="collapse-item rounded-xl bg-(--btn-regular-bg) overflow-hidden"
      >
        <button
          type="button"
          class="collapse-header flex w-full items-center justify-between p-4 text-left transition"
          data-collapse-target="owner-info"
        >
          <div class="flex items-center gap-2">
            <span class="icon-[material-symbols--person-outline-rounded] text-xl text-(--primary)"></span>
            <span class="font-medium text-90">个人博客信息</span>
          </div>
          <span class="collapse-icon icon-[material-symbols--expand-more-rounded] text-xl text-50 transition-transform duration-200" th:classappend="${theme.config.links.expand_owner_info} ? 'is-expanded'" data-expanded-class="is-expanded"></span>
        </button>
        <div
          id="owner-info"
          class="collapse-content" th:classappend="${!theme.config.links.expand_owner_info} ? 'hidden'"
        >
          <div class="px-4 pb-4 -mt-2">
            <!-- 信息列表 -->
            <div class="space-y-0 text-sm">
              <!-- 名称 -->
              <div class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5">
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">名称：</span>
                  <span class="text-50 truncate" th:text="${theme.config.links.owner_name}">博客名称</span>
                </div>
                <button
                  type="button"
                  class="copy-btn rounded-md p-0.5 text-30 transition hover:text-(--primary)"
                  th:attr="data-copy-text=${theme.config.links.owner_name}"
                  title="复制"
                >
                  <span class="icon-[material-symbols--content-copy-rounded] text-sm"></span>
                </button>
              </div>
              <!-- 描述 -->
              <div class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5">
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">描述：</span>
                  <span class="truncate text-50" th:text="${theme.config.links.owner_description}">博客描述</span>
                </div>
                <button
                  type="button"
                  class="copy-btn rounded-md p-0.5 text-30 transition hover:text-(--primary)"
                  th:attr="data-copy-text=${theme.config.links.owner_description}"
                  title="复制"
                >
                  <span class="icon-[material-symbols--content-copy-rounded] text-sm"></span>
                </button>
              </div>
              <!-- 头像链接 -->
              <div class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5">
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">头像：</span>
                  <a th:href="${theme.config.links.owner_avatar}" class="truncate text-(--primary) hover:underline" th:text="${theme.config.links.owner_avatar}">https://example.com/avatar.jpg</a>
                </div>
                <button
                  type="button"
                  class="copy-btn rounded-md p-0.5 text-30 transition hover:text-(--primary)"
                  th:attr="data-copy-text=${theme.config.links.owner_avatar}"
                  title="复制"
                >
                  <span class="icon-[material-symbols--content-copy-rounded] text-sm"></span>
                </button>
              </div>
              <!-- 网址 -->
              <div class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5">
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">网址：</span>
                  <a th:href="${theme.config.links.owner_url}" class="truncate text-(--primary) hover:underline" th:text="${theme.config.links.owner_url}">https://example.com</a>
                </div>
                <button
                  type="button"
                  class="copy-btn rounded-md p-0.5 text-30 transition hover:text-(--primary)"
                  th:attr="data-copy-text=${theme.config.links.owner_url}"
                  title="复制"
                >
                  <span class="icon-[material-symbols--content-copy-rounded] text-sm"></span>
                </button>
              </div>
              <!-- RSS -->
              <div class="info-item flex items-center justify-between gap-2 rounded-lg bg-(--bg-secondary) py-1.5 px-2 pl-5">
                <div class="flex items-center gap-2 min-w-0 flex-1">
                  <span class="text-90">RSS：</span>
                  <a th:href="${theme.config.links.owner_rss}" class="truncate text-(--primary) hover:underline" th:text="${theme.config.links.owner_rss}">/rss.xml</a>
                </div>
                <button
                  type="button"
                  class="copy-btn rounded-md p-0.5 text-30 transition hover:text-(--primary)"
                  th:attr="data-copy-text=${theme.config.links.owner_rss}"
                  title="复制"
                >
                  <span class="icon-[material-symbols--content-copy-rounded] text-sm"></span>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- 友链须知 -->
      <div
        th:if="${theme.config.links.enable_requirements && not #strings.isEmpty(theme.config.links.requirements)}"
        class="collapse-item rounded-xl bg-(--btn-regular-bg) overflow-hidden"
      >
        <button
          type="button"
          class="collapse-header flex w-full items-center justify-between p-4 text-left transition"
          data-collapse-target="requirements"
        >
          <div class="flex items-center gap-2">
            <span class="icon-[material-symbols--checklist-rounded] text-xl text-(--primary)"></span>
            <span class="font-medium text-90">友链须知</span>
          </div>
          <span class="collapse-icon icon-[material-symbols--expand-more-rounded] text-xl text-50 transition-transform duration-200"></span>
        </button>
        <div
          id="requirements"
          class="collapse-content hidden"
        >
          <div class="px-4 pb-4 -mt-2">
            <ul
              th:if="${not #strings.isEmpty(theme.config.links.requirements)}"
              class="requirements-list list-outside list-disc space-y-1 text-sm text-50 pl-5"
              th:data-text="${theme.config.links.requirements}"
            ></ul>
          </div>
        </div>
      </div>

      <!-- 免责申明 -->
      <div
        th:if="${theme.config.links.enable_disclaimer && not #strings.isEmpty(theme.config.links.disclaimer)}"
        class="collapse-item rounded-xl bg-(--btn-regular-bg) overflow-hidden"
      >
        <button
          type="button"
          class="collapse-header flex w-full items-center justify-between p-4 text-left transition"
          data-collapse-target="disclaimer"
        >
          <div class="flex items-center gap-2">
            <span class="icon-[material-symbols--warning-outline-rounded] text-xl text-(--primary)"></span>
            <span class="font-medium text-90">免责申明</span>
          </div>
          <span class="collapse-icon icon-[material-symbols--expand-more-rounded] text-xl text-50 transition-transform duration-200"></span>
        </button>
        <div
          id="disclaimer"
          class="collapse-content hidden"
        >
          <div class="px-4 pb-4 -mt-2">
            <ul
              class="disclaimer-list list-outside list-disc space-y-1 text-sm text-50 pl-5"
              th:data-text="${theme.config.links.disclaimer}"
            ></ul>
          </div>
        </div>
      </div>
    </div>

    <!-- 申请友链按钮 - 放在折叠面板下方 -->
    <div th:if="${theme.config.links.enable_apply_btn}" class="mt-4 flex justify-center">
      <a
        href="javascript:LinkSubmitWidget.open()"
        class="btn-regular scale-animation inline-flex items-center gap-2 rounded-lg px-6 py-2.5 text-sm font-bold active:scale-95"
      >
        <span>申请友链</span>
        <span class="icon-[material-symbols--add-rounded] text-lg"></span>
      </a>
    </div>
  </section>

  <!-- 评论区 -->
  <div
    id="comment"
    th:if="${haloCommentEnabled}"
    class="card-base relative z-10 w-full px-6 pb-4 pt-6 md:px-9"
  >
    <h2
      class="mb-2 text-base font-medium text-gray-900 dark:text-slate-50"
      th:text="#{common.comment}"
    >
      评论
    </h2>
    <Fragment
      set:html={'<halo:comment group="plugin.halo.run" kind="Plugin" th:attr="name=${pluginName}" />'}
    />
  </div>
</MainGridLayout>

<!-- 折叠面板和复制功能脚本 -->
<script is:inline>
  (function() {
    // 折叠面板交互
    document.addEventListener('click', function(e) {
      var header = e.target.closest('[data-collapse-target]');
      if (!header) return;

      var targetId = header.getAttribute('data-collapse-target');
      var content = document.getElementById(targetId);
      var icon = header.querySelector('.collapse-icon');

      if (content) {
        var isHidden = content.classList.contains('hidden');

        // 关闭所有面板
        document.querySelectorAll('.collapse-content').forEach(function(c) {
          c.classList.add('hidden');
        });
        document.querySelectorAll('.collapse-icon').forEach(function(i) {
          i.classList.remove('is-expanded');
        });

        // 切换当前项（如果是折叠的则展开）
        if (isHidden) {
          content.classList.remove('hidden');
          if (icon) {
            icon.classList.add('is-expanded');
          }
          // 初始化当前面板内的复制按钮
          initCopyButtonsInPanel(content);
        }
      }
    });

    // 复制功能
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.copy-btn');
      if (!btn || btn.dataset.copyBound) return;
      
      btn.dataset.copyBound = 'true';
      btn.addEventListener('click', handleCopy);
    });

    // 页面加载时，初始化默认展开的面板的复制按钮
    var defaultExpanded = document.querySelector('.collapse-content:not(.hidden)');
    if (defaultExpanded) {
      initCopyButtonsInPanel(defaultExpanded);
    }
  })();

  function initCopyButtonsInPanel(panel) {
    var buttons = panel.querySelectorAll('.copy-btn');
    buttons.forEach(function(btn) {
      if (btn.dataset.copyBound) return;
      btn.dataset.copyBound = 'true';
      btn.addEventListener('click', handleCopy);
    });
  }

  function handleCopy() {
    var btn = this;
    var text = btn.getAttribute('data-copy-text');
    if (!text) {
      var container = btn.closest('.flex');
      if (container) {
        var link = container.querySelector('a');
        if (link) {
          text = link.href || link.textContent;
        }
      }
    }

    if (text) {
      text = text.trim();
      var originalContent = btn.innerHTML;
      btn.innerHTML = '<span class="text-sm font-medium">已复制</span>';
      btn.disabled = true;
      btn.classList.add('!text-green-500');

      var copyText = text;
      var restoreBtn = function() {
        btn.innerHTML = originalContent;
        btn.disabled = false;
        btn.classList.remove('!text-green-500');
      };

      navigator.clipboard.writeText(copyText).then(function() {
        setTimeout(restoreBtn, 3000);
      }).catch(function() {
        var textarea = document.createElement('textarea');
        textarea.value = copyText;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
        setTimeout(restoreBtn, 3000);
      });
    }
  }

  function showCopyToast(message) {
    var existingToast = document.querySelector('.copy-toast');
    if (existingToast) {
      existingToast.remove();
    }

    var toast = document.createElement('div');
    toast.className = 'copy-toast fixed bottom-6 left-1/2 -translate-x-1/2 z-[9999] rounded-lg bg-(--primary) px-4 py-2 text-sm font-medium text-white shadow-lg';
    toast.textContent = message;
    document.body.appendChild(toast);

    setTimeout(function() {
      toast.style.opacity = '0';
      toast.style.transition = 'opacity 0.3s';
      setTimeout(function() {
        toast.remove();
      }, 300);
    }, 2000);
  }

  // 渲染友链须知和免责申明列表
  function renderRequirementsList() {
    var lists = document.querySelectorAll('.requirements-list, .disclaimer-list');
    lists.forEach(function(list) {
      if (list.hasAttribute('data-rendered')) {
        return;
      }
      var text = list.getAttribute('data-text');
      if (text) {
        var lines = text.split('\n');
        lines.forEach(function(line) {
          if (line.trim()) {
            var li = document.createElement('li');
            li.textContent = line.trim();
            list.appendChild(li);
          }
        });
        list.setAttribute('data-rendered', 'true');
      }
    });
  }

  // 渲染友链须知和免责申明列表
  function renderRequirementsList() {
    var lists = document.querySelectorAll('.requirements-list, .disclaimer-list');
    lists.forEach(function(list) {
      if (list.dataset.rendered) return;
      list.dataset.rendered = 'true';
      
      var text = list.getAttribute('data-text');
      if (text) {
        var lines = text.split('\n');
        lines.forEach(function(line) {
          if (line.trim()) {
            var li = document.createElement('li');
            li.textContent = line.trim();
            list.appendChild(li);
          }
        });
      }
    });
  }

  // 初始化所有功能
  function initAll() {
    initCopyButtonsInPanel(document);
    renderRequirementsList();
    // 重新初始化默认展开面板的复制按钮
    var defaultExpanded = document.querySelector('.collapse-content:not(.hidden)');
    if (defaultExpanded) {
      initCopyButtonsInPanel(defaultExpanded);
    }
  }

  // DOM 加载完成后初始化
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll);
  } else {
    initAll();
  }
</script>
